<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="BlackNotepad.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="#000000"
    mc:Ignorable="d">

    <Grid Background="#000000">
        <Grid
            x:Name="MarkdownWorkspace"
            Background="#000000">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="EditorColumn" Width="*" />
                <ColumnDefinition x:Name="PreviewColumn" Width="0" />
            </Grid.ColumnDefinitions>

            <TextBox
                x:Name="Editor"
                Padding="32"
                AcceptsReturn="True"
                AutomationProperties.AutomationId="MarkdownEditor"
                AutomationProperties.Name="Markdown editor"
                Background="#000000"
                BorderBrush="Transparent"
                BorderThickness="0"
                FontFamily="Assets/Fonts/InstrumentSerif-Regular.ttf#Instrument Serif"
                FontSize="32"
                Foreground="#FFFFFF"
                HorizontalAlignment="Stretch"
                IsSpellCheckEnabled="False"
                ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                ScrollViewer.VerticalScrollBarVisibility="Hidden"
                TextChanged="Editor_TextChanged"
                TextWrapping="Wrap"
                VerticalAlignment="Stretch">
                <TextBox.Resources>
                    <SolidColorBrush x:Key="TextControlBackground" Color="#000000" />
                    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#000000" />
                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#000000" />
                    <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlForeground" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="#FFFFFF" />
                </TextBox.Resources>
            </TextBox>

            <Border
                x:Name="PreviewPane"
                Grid.Column="1"
                Background="#080808"
                BorderBrush="#202020"
                BorderThickness="1,0,0,0"
                Visibility="Collapsed">
                <ScrollViewer Padding="32" VerticalScrollBarVisibility="Auto">
                    <RichTextBlock
                        x:Name="MarkdownPreview"
                        AutomationProperties.Name="Markdown preview"
                        FontFamily="Assets/Fonts/InstrumentSerif-Regular.ttf#Instrument Serif"
                        FontSize="28"
                        Foreground="#FFFFFF"
                        TextWrapping="Wrap" />
                </ScrollViewer>
            </Border>
        </Grid>

        <ScrollViewer
            x:Name="SettingsView"
            Padding="24"
            Background="#1F1B1A"
            VerticalScrollBarVisibility="Auto"
            Visibility="Collapsed">
            <StackPanel x:Name="SettingsContent" Spacing="12" />
        </ScrollViewer>
    </Grid>
</Page>
