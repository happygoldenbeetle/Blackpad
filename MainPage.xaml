<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="BlackNotepad.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="#000000"
    mc:Ignorable="d">

    <Grid Background="#000000">
        <RichEditBox
            x:Name="Editor"
            Padding="32"
            AcceptsReturn="True"
            AutomationProperties.AutomationId="TextEditor"
            AutomationProperties.Name="Text editor"
            Background="#000000"
            BorderBrush="Transparent"
            BorderThickness="0"
            FontFamily="Assets/Fonts/InstrumentSerif-Regular.ttf#Instrument Serif"
            FontSize="32"
            Foreground="#FFFFFF"
            HorizontalAlignment="Stretch"
            IsSpellCheckEnabled="False"
            ScrollViewer.HorizontalScrollBarVisibility="Hidden"
            ScrollViewer.VerticalScrollBarVisibility="Hidden"
            TextWrapping="Wrap"
            VerticalAlignment="Stretch"
            PointerWheelChanged="Editor_PointerWheelChanged"
            TextChanged="Editor_TextChanged">
            <RichEditBox.Resources>
                <SolidColorBrush x:Key="TextControlBackground" Color="#000000" />
                <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#000000" />
                <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#000000" />
                <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent" />
                <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />
                <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
                <SolidColorBrush x:Key="TextControlForeground" Color="#FFFFFF" />
                <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#FFFFFF" />
                <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="#FFFFFF" />
            </RichEditBox.Resources>
        </RichEditBox>

        <!--  Live word/character count  -->
        <TextBlock
            x:Name="CountLabel"
            Margin="0,0,20,14"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            FontFamily="Assets/Fonts/InstrumentSerif-Regular.ttf#Instrument Serif"
            FontSize="13"
            Foreground="#FFFFFF"
            IsHitTestVisible="False"
            Opacity="0.35" />

        <ScrollViewer
            x:Name="SettingsView"
            Padding="24"
            Background="#1F1B1A"
            IsTabStop="True"
            UseSystemFocusVisuals="False"
            VerticalScrollBarVisibility="Auto"
            Visibility="Collapsed">
            <StackPanel x:Name="SettingsContent" Spacing="12" />
        </ScrollViewer>
    </Grid>
</Page>
